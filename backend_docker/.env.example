# 复制为 backend_docker/.env 后填写（.env 勿提交 Git）

# 容器对外端口（须与 docker-compose 中 ports 一致）
SERVER_PORT=9019

# MySQL（lab_assess 表所在库）
DB_HOST=sql.z150.vhostgo.com
DB_PORT=3306
DB_NAME=wisesun
DB_USERNAME=wisesun
DB_PASSWORD=anfang250923
DB_TIMEZONE=Asia/Shanghai
DB_JDBC_PARAMS=useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true

# JPA
JPA_SHOW_SQL=false

# CORS：生产环境改为实际前端域名，逗号分隔
# 例：https://your-domain.com,https://www.your-domain.com
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

# 可选：.env 不在 /app/.env 时指定绝对路径
# DOTENV_PATH=/app/.env
